rompts":[{"id":1,"type":"bot-nudge","data":{"context":"In case you are not able to think of any answer, you can get help from Ms. Greenline","text":"Can you tell me what are some things that money can and can't buy?","reply":"You can buy goods and services, like toys, cars, healthcare, house, etc. with money. \n\nHaving really good habits, being honest, and showing respect for our teachers and parents can’t be bought using money."}}],"dialogues":[],"active":true,"id":"6557a41e782e953a4671715e"},{"moduleId":"FINX101","rank":30,"template":"readonly","templateOptions":{"styles":{"backgroundImage":"url(/assets/images/modules/demo-FINX101/task-bg-teacher.png)","backgroundSize":"100% 100%","backgroundPosition":"center"}},"content":{"sections":[{"type":"image","value":"/assets/images/modules/demo-FINX101/question-dots.png","style":{"height":"6rem"}},{"type":"text-heading","value":"Do you know what Goods & Services are?","style":{"fontWeight":"700"}}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[],"active":true,"id":"6557a41f782e953a46717161"},{"moduleId":"FINX101","rank":31,"template":"readonly","templateOptions":{"styles":{"backgroundImage":"url(/assets/images/modules/demo-FINX101/task-bg.png)","backgroundSize":"100% 100%","backgroundPosition":"center"}},"content":{"sections":[{"type":"image","value":"/assets/images/modules/demo-FINX101/goods-services.png"}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[],"active":true,"id":"6557a41f782e953a46717164"},{"moduleId":"FINX101","rank":32,"template":"readonly","templateOptions":{"styles":{"backgroundImage":"url(/assets/images/modules/demo-FINX101/task-bg-teacher.png)","backgroundSize":"100% 100%","backgroundPosition":"center"}},"content":{"sections":[{"type":"image","value":"/assets/images/modules/demo-FINX101/star.png","style":{"height":"6rem"}},{"type":"text-heading","value":"Let’s discuss some examples.","style":{"fontWeight":"700"}},{"type":"image","value":"/assets/images/modules/demo-FINX101/goods-services-2.png"}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[],"active":true,"id":"6557a41f782e953a46717167"},{"moduleId":"FINX101","rank":33,"template":"readonly","templateOptions":{"styles":{"backgroundImage":"url(/assets/images/modules/demo-FINX101/task-bg.png)","backgroundSize":"100% 100%","backgroundPosition":"center"}},"content":{"sections":[{"type":"image","value":"/assets/images/modules/demo-FINX101/question-bulb.png","style":{"height":"6rem"}},{"type":"text-heading","value":"Gear up for a fun challenge. \nIt's quiz time! ","style":{"fontWeight":"700"}}],"actions":[{"id":1,"variant":"primary","contents":[{"type":"text","value":"Start Assessment"}]}]},"characters":[],"prompts":[],"dialogues":[],"active":true,"id":"6557a420782e953a4671716a"},{"moduleId":"FINX101","rank":34,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":1,"question":{"id":1,"contents":[{"type":"text","value":"Goods or Sevice","style":{"fontWeight":"400"}},{"type":"text-heading","value":"I stand in a cup when I'm not in use, \nWith bristles on top for cleaning use."}]},"options":[{"id":1,"isCorrect":true,"contents":[{"type":"text","value":"Goods"}]},{"id":2,"isCorrect":false,"contents":[{"type":"text","value":"Service"}]}],"explaination":[{"type":"text","value":"The correct answer is \"Goods\" because the riddle talks about a toothbrush, which is an item you can touch and own, not a service that someone performs for you."}]},"dialogues":[],"active":true,"id":"6557a420782e953a4671716d"},{"moduleId":"FINX101","rank":35,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":2,"question":{"id":1,"contents":[{"type":"text","value":"Goods or Sevice","style":{"fontWeight":"400"}},{"type":"text-heading","value":"In the morning sun, I come your way, \nCarrying students to learn and play."}]},"options":[{"id":1,"isCorrect":false,"contents":[{"type":"text","value":"Goods"}]},{"id":2,"isCorrect":true,"contents":[{"type":"text","value":"Service"}]}],"explaination":[{"type":"text","value":"The correct answer is \"Service\" because this riddle describes a school bus, which provides the service of transportation, taking students to and from school, not a physical item you can own."}]},"dialogues":[],"active":true,"id":"6557a420782e953a46717170"},{"moduleId":"FINX101","rank":36,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":3,"question":{"id":1,"contents":[{"type":"text-heading","value":"Dollar is the currency of which country?"}]},"options":[{"id":1,"isCorrect":true,"contents":[{"type":"text","value":"United States of America"}]},{"id":2,"isCorrect":false,"contents":[{"type":"text","value":"United Kingdom"}]},{"id":3,"isCorrect":false,"contents":[{"type":"text","value":"Indonesia"}]},{"id":4,"isCorrect":false,"contents":[{"type":"text","value":"Sweden"}]}],"explaination":[{"type":"text","value":"The correct answer is \"United States of America\" because the dollar is the name of the money used there, not in the United Kingdom, Indonesia, or Sweden."}]},"dialogues":[],"active":true,"id":"6557a421782e953a46717173"},{"moduleId":"FINX101","rank":37,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":4,"question":{"id":1,"contents":[{"type":"text","value":"Goods or Sevice","style":{"fontWeight":"400"}},{"type":"text-heading","value":"Is an “iPhone” a good or a service?"}]},"options":[{"id":1,"isCorrect":true,"contents":[{"type":"text","value":"Goods"}]},{"id":2,"isCorrect":false,"contents":[{"type":"text","value":"Service"}]}],"explaination":[{"type":"text","value":"An \"iPhone\" is a \"Good\" because it's a physical item you can buy and keep, unlike a service, which is something someone does for you."}]},"dialogues":[],"active":true,"id":"6557a421782e953a46717176"},{"moduleId":"FINX101","rank":38,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":5,"question":{"id":1,"contents":[{"type":"text","value":"Goods or Sevice","style":{"fontWeight":"400"}},{"type":"text-heading","value":"Is a “Taxi ride” a good or a service?"}]},"options":[{"id":1,"isCorrect":false,"contents":[{"type":"text","value":"Goods"}]},{"id":2,"isCorrect":true,"contents":[{"type":"text","value":"Service"}]}],"explaination":[{"type":"text","value":"The correct answer is \"Service\" because a taxi is something you use for a ride from one place to another. It's a service provided by a driver, not an item that you can own."}]},"dialogues":[],"active":true,"id":"6557a421782e953a46717179"},{"moduleId":"FINX101","rank":39,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":6,"questionNumber":6,"question":{"id":1,"contents":[{"type":"text-heading","value":"What can you buy with money?"}]},"options":[{"id":1,"isCorrect":false,"contents":[{"type":"text","value":"Happiness"}]},{"id":2,"isCorrect":false,"contents":[{"type":"text","value":"Good Habits"}]},{"id":3,"isCorrect":true,"contents":[{"type":"text","value":"Chocolates"}]}],"explaination":[{"type":"text","value":"The correct answer is \"Chocolates\", because they are a treat you can purchase with money, unlike happiness or good habits, which cannot be bought but are developed or felt."}]},"dialogues":[],"active":true,"id":"6557a422782e953a4671717c"},{"moduleId":"FINX101","rank":40,"template":"activity-character-feedback","characters":[],"prompts":[],"dialogues":[],"active":true,"audio":{"sources":["/assets/modules/FINX/audio/feedback-greenlin