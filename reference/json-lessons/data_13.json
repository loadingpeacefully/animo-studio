dules/FINX202.mp4"}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[{"sender":"Greenline","text":"Money was created to overcome the limitations of barter systems and to serve as a universally accepted medium of exchange. Its invention has played a fundamental role in the development and functioning of modern economies."},{"sender":"Greenline","text":"Let's learn about the same through a video."}],"active":true,"id":"6557a43f782e953a46717268"},{"moduleId":"FINX202","rank":16,"template":"readonly","content":{"sections":[{"type":"text","value":"Did you know?"},{"type":"image","value":"/assets/images/modules/demo-FINX202/fact-1.png"}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[{"sennder":"Greenline","text":"That was an exciting journey to explore the world of global currencies."}],"active":true,"id":"6557a440782e953a4671726b"},{"moduleId":"FINX202","rank":17,"template":"activity-conversation","characters":[],"prompts":[],"dialogues":[],"conversation":{"background":"/assets/images/backgrounds/bg-6.svg","foreground":"/assets/images/backgrounds/fr-4.svg","actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}],"characters":[{"type":"animation","activeAnimation":"right_loop","idleAnimation":"right_idle","animations":[{"type":"json","value":"/assets/animations/ray.json"},{"type":"atlas","value":"/assets/animations/ray.atlas"}],"name":"RAY","color":"#E85146","dialogues":[{"type":"text","value":"By the way, what does the word “FIAT” mean? I thought it was the make of a car!"}],"url":"/assets/characters/ray-talking.svg"},{"type":"animation","activeAnimation":"left_loop","idleAnimation":"left_idle","animations":[{"type":"json","value":"/assets/animations/max.json"},{"type":"atlas","value":"/assets/animations/max.atlas"}],"name":"MAX","color":"#2CC3BF","url":"/assets/characters/max-talking.svg"}]},"audio":{"sources":["/assets/audio/modules/demo-FINX202/ray-6.mp3"]},"active":true,"id":"6557a440782e953a4671726e"},{"moduleId":"FINX202","rank":18,"template":"readonly","content":{"sections":[{"type":"text","value":"Did you know?"},{"type":"image","value":"/assets/images/modules/demo-FINX202/fact-2.png"}],"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[{"sennder":"Greenline","text":"Also, for your information, government-issued Fiat money banknotes were used first during the 13th century in China."}],"active":true,"id":"6557a440782e953a46717271"},{"moduleId":"FINX202","rank":19,"template":"activity-conversation","characters":[],"prompts":[],"dialogues":[],"conversation":{"background":"/assets/images/backgrounds/bg-6.svg","foreground":"/assets/images/backgrounds/fr-4.svg","actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}],"characters":[{"type":"animation","activeAnimation":"right_loop","idleAnimation":"right_idle","animations":[{"type":"json","value":"/assets/animations/ray.json"},{"type":"atlas","value":"/assets/animations/ray.atlas"}],"name":"RAY","color":"#E85146","url":"/assets/characters/ray-talking.svg"},{"type":"animation","activeAnimation":"left_loop","idleAnimation":"left_idle","animations":[{"type":"json","value":"/assets/animations/max.json"},{"type":"atlas","value":"/assets/animations/max.atlas"}],"name":"MAX","color":"#2CC3BF","url":"/assets/characters/max-talking.svg","dialogues":[{"type":"text-rich","value":["This is getting interesting every minute, I have always wanted to know about the different currencies used in different parts of the world. Infact, I want to be a ",{"type":"prompt","value":{"valueText":"Define Numismatic","displayText":"numismatic"}}]}]}]},"audio":{"sources":["/assets/audio/modules/demo-FINX202/max-4.mp3"]},"active":true,"id":"6557a441782e953a46717274"},{"moduleId":"FINX202","rank":20,"template":"activity-labelling","characters":[],"prompts":[],"dialogues":[],"labelling":{"flow":"vertical","question":[{"type":"text","value":"Can you recognise these currencies?"}],"imageConfig":{"imageWidth":600,"imageHeight":300,"imageUrl":"/assets/images/modules/demo-FINX202/currency-labelling.png","imageBackgroundStyle":{"backgroundColor":"#EBF5FF"}},"labels":[{"target":{"x":200,"y":100},"option":[{"type":"text","value":"US Dollar"}]},{"target":{"x":480,"y":100},"option":[{"type":"text","value":"Pound Sterling"}]},{"target":{"x":200,"y":250},"option":[{"type":"text","value":"Japanese Yen"}]},{"target":{"x":480,"y":250},"option":[{"type":"text","value":"Euro"}]}]},"active":true,"id":"6557a441782e953a46717277"},{"moduleId":"FINX202","rank":21,"template":"activity-reorder","templateOptions":{"styles":{"backgroundImage":"url(/assets/images/task-bg.svg)"}},"characters":[],"prompts":[{"id":1,"type":"bot-nudge","data":{"text":"Hey, Ms. Greenline, can you help me with the top 4 most traded currencies of the world?","context":"If you need help Champ, let's ask Ms. Greenline."}}],"dialogues":[],"dragAndDrop":{"subjective":true,"question":[{"type":"image","value":"/assets/icons/question-mark-icon.svg","style":{"height":"4.5rem"}},{"type":"text","value":"Now let's reorder them according to their global importance and usage."},{"type":"text-rich","value":[{"type":"link","value":{"valueText":"https://en.wikipedia.org/wiki/Template:Most_traded_currencies","displayText":"Check the most traded currencies"},"style":{"fontSize":"1.1rem","textDecoration":"underline"}}]}],"categories":[{"options":[{"content":[{"type":"text","value":"US Dollar"}]}]},{"options":[{"content":[{"type":"text","value":"Pound Sterling"}]}]},{"options":[{"content":[{"type":"text","value":"Euro"}]}]},{"options":[{"content":[{"type":"text","value":"Japanese Ye"}]}]}]},"active":true,"id":"6557a441782e953a4671727a"},{"moduleId":"FINX202","rank":22,"template":"readonly","templateOptions":{"styles":{"backgroundColor":"#EDFFEF","backgroundImage":"url(/assets/images/backgrounds/assessment-start-bg.svg)"}},"content":{"sections":[{"type":"image","value":"/assets/images/great-work.svg","style":{"height":"7.5rem"}},{"type":"text","value":"Time to assess your understanding"}],"actions":[{"id":1,"variant":"primary","contents":[{"type":"text","value":"Start Assessment"},{"type":"image","value":"/assets/icons/chevron-right.svg"}]}]},"characters":[],"prompts":[],"dialogues":[{"sender":"Greeline","text":"That was a lot of work indeed, but this knowledge will definitely add zest to your financial acumen. It's time for a performance assessment to track your progress."}],"active":true,"id":"6557a442782e953a4671727d"},{"moduleId":"FINX202","rank":23,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":5,"questionNumber":1,"question":{"id":1,"contents":[{"type":"text","value":"Fiat money is backed by a physical commodity like gold or silver."}]},"options":[{"id":1,"contents":[{"type":"text","value":"True"}],"isCorrect":false},{"id":2,"contents":[{"type":"text","value":"False"}],"isCorrect":true}],"explaination":[{"type":"text","value":"Fiat money is not backed by any physical commodity; its value is based on trust in the government that issues it."}]},"dialogues":[],"active":true,"id":"6557a442782e953a46717280"},{"moduleId":"FINX202","rank":24,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":5,"questionNumber":2,"question":{"id":1,"contents":[{"type":"text","value":"Fiat money has intrinsic value because it can be used for various purposes."}]},"options":[{"id":1,"contents":[{"type":"text","value":"True"}],"isCorrect":false},{"id":2,"contents":[{"type":"text","value":"False"}],"isCorrect":true}],"explaination":[{"type":"text","value":"Fiat money does not have intrinsic value; its value is derived from the trust and confidence people have in it as a medium of exchange."}]},"dialogues":[],"active":true,"id":"6557a442782e953a46717283"},{"moduleId":"FINX202","rank":25,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":5,"questionNumber":3,"question":{"id":1,"contents":[{"type":"text","value":"Fiat money is always issued and controlled by a central bank."}]},"options":[{"id":1,"contents":[{"type":"text","value":"True"}],"isCorrect":true},{"id":2,"contents":[{"type":"text","value":"False"}],"isCorrect":false}],"explaination":[{"type":"text","value":"Fiat money is typically issued and regulated by a central authority, such as a central bank or government."}]},"dialogues":[],"active":true,"id":"6557a443782e953a46717286"},{"moduleId":"FINX202","rank":26,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":5,"questionNumber":4,"question":{"id":1,"contents":[{"type":"text","value":"Copying or replicating fiat money is not a crime."}]},"options":[{"id":1,"contents":[{"type":"text","value":"True"}],"isCorrect":false},{"id":2,"contents":[{"type":"text","value":"False"}],"isCorrect":true}],"explaination":[{"type":"text","value":"Counterfeiting fiat money is illegal and can have serious economic consequences, as it undermines the trust in the currency."}]},"dialogues":[],"active":true,"id":"6557a443782e953a46717289"},{"moduleId":"FINX202","rank":27,"template":"activity-mcq","characters":[],"prompts":[],"mcq":{"variant":"assessment","totalQuestions":5,"questionNumber":5,"question":{"id":1,"contents":[{"type":"text","value":"Do you think countries can come together to use one currency?"}]},"options":[{"id":1,"contents":[{"type":"text","value":"True"}],"isCorrect":false},{"id":2,"contents":[{"type":"text","value":"False"}],"isCorrect":true}],"explaination":[{"type":"text","value":"Most countries have their own national currencies or fiat money. These currencies are issued and regulated by their respective central banks or monetary authorities. While some regions, like the European Union, have adopted a common currency (the Euro), the vast majority of countries maintain their own separate currencies."}]},"dialogues":[],"active":true,"id":"6557a443782e953a4671728c"},{"moduleId":"FINX202","rank":28,"template":"activity-typeform","characters":[],"prompts":[],"dialogues":[],"typeform":{"formId":"Ac5ewOCT","allowedHiddenFields":["userId","course","grade","userName","studentName","teacherName","studentBookingId","moduleId","role","environment","taskId"],"style":{"height":"100%","width":"100%"},"actions":[{"id":1,"variant":"icon","contents":[{"type":"image","value":"/assets/icons/arrow-right.svg"}]}]},"active":true,"id":"6557a444782e953a4671728f"}]